# Cross-platform line-ending policy.
#
# All text files are normalized to LF in the repo and on checkout, on every OS.
# Without this, Windows git checkout converts LF -> CRLF, which causes the
# biome formatter (LF-expecting) to fail in CI even though the files were
# clean when committed.

* text=auto eol=lf

# Binary files — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.pdf   binary
*.zip   binary
*.gz    binary
*.tgz   binary
*.tar   binary
*.woff  binary
*.woff2 binary
