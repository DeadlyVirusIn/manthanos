{
  "name": "@manthanos/orchestrator",
  "version": "0.0.0",
  "description": "ManthanOS orchestrator — workflow runner that ties context packing, adapter invocation, safety gating, and audited writes.",
  "license": "BSL-1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@manthanos/adapters-sdk": "workspace:*",
    "@manthanos/context": "workspace:*",
    "@manthanos/memory": "workspace:*",
    "@manthanos/platform": "workspace:*",
    "@manthanos/safety": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
