{
  "name": "@manthanos/adapter-claude",
  "version": "0.0.0",
  "description": "Anthropic Claude adapter for ManthanOS. Implements AgentAdapter against the official @anthropic-ai/sdk.",
  "license": "BSL-1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
