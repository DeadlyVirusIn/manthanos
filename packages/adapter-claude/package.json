  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@manthanos/adapters-sdk": "workspace:*",
    "@manthanos/platform": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
